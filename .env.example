# ApeChain Mainnet Configuration
APECHAIN_MAINNET_RPC_URL="https://apechain.calderachain.xyz/http"
APECHAIN_MAINNET_CHAIN_ID="33139"

# Deployer Configuration
# REPLACE: Copy from nft-collage/.env or use your own deployer private key
DEPLOYER_PRIVATE_KEY="0xREPLACE_WITH_YOUR_PRIVATE_KEY"

# Stabilization System Configuration
STAB_DAY_SECONDS="60"
# Generate with: cast keccak "nmgi-stab-entropy-$(date +%Y-%m-%d)"
STAB_ENTROPY_SEED="0xREPLACE_WITH_GENERATED_ENTROPY_SEED"

# Item Admin Recipient (deployer wallet receives 1 of each item on deploy)
# REPLACE: Get deployer address with: cast wallet address --private-key $DEPLOYER_PRIVATE_KEY
ITEM_ADMIN_RECIPIENT="0xREPLACE_WITH_DEPLOYER_ADDRESS"

# Optional: For DeployItemCatalog script (set after initial deployment)
ITEM_TOKEN_PROXY=""
ITEM_CATALOG_PROXY=""
ITEM_IMAGE_DEPLOYER=""
PROXY_ADMIN=""

# Optional: For SmokeStabilizationSystem script (set after deployment)
STAB_CREATURE_STABILIZER=""
STAB_ITEM_CATALOG=""
STAB_ITEM_TOKEN=""
